# Custom Snort IDS Rules — Tanay Shirsat SOC Home Lab
# ATT&CK mappings included for each rule
# Tuned to reduce false positives by ~30% through threshold controls

# ─────────────────────────────────────────
# RECONNAISSANCE DETECTION
# MITRE ATT&CK: T1046 - Network Service Scanning
# ─────────────────────────────────────────
alert tcp any any -> $HOME_NET any (msg:"SOC-LAB RECON: TCP Port Scan Detected"; flags:S; threshold: type threshold, track by_src, count 20, seconds 10; classtype:network-scan; sid:1000001; rev:1;)

alert udp any any -> $HOME_NET any (msg:"SOC-LAB RECON: UDP Port Scan Detected"; threshold: type threshold, track by_src, count 20, seconds 10; classtype:network-scan; sid:1000002; rev:1;)

# ─────────────────────────────────────────
# BRUTE FORCE DETECTION
# MITRE ATT&CK: T1110 - Brute Force
# ─────────────────────────────────────────
alert tcp any any -> $HOME_NET 22 (msg:"SOC-LAB BRUTEFORCE: SSH Brute Force Attempt"; flow:to_server,established; content:"SSH"; threshold: type threshold, track by_src, count 5, seconds 60; classtype:attempted-user; sid:1000003; rev:1;)

alert tcp any any -> $HOME_NET 3389 (msg:"SOC-LAB BRUTEFORCE: RDP Brute Force Attempt"; flow:to_server,established; threshold: type threshold, track by_src, count 5, seconds 60; classtype:attempted-user; sid:1000004; rev:1;)

alert tcp any any -> $HOME_NET 445 (msg:"SOC-LAB BRUTEFORCE: SMB Login Brute Force"; flow:to_server,established; content:"|00 00 00 00|"; threshold: type threshold, track by_src, count 10, seconds 60; classtype:attempted-user; sid:1000005; rev:1;)

# ─────────────────────────────────────────
# C2 CALLBACK DETECTION
# MITRE ATT&CK: T1071 - Application Layer Protocol
# ─────────────────────────────────────────
alert tcp $HOME_NET any -> any 4444 (msg:"SOC-LAB C2: Metasploit Default Port Outbound"; flow:to_server,established; classtype:trojan-activity; sid:1000006; rev:1;)

alert tcp $HOME_NET any -> any 1337 (msg:"SOC-LAB C2: Suspicious Outbound C2 Port 1337"; flow:to_server,established; classtype:trojan-activity; sid:1000007; rev:1;)

alert dns any any -> any any (msg:"SOC-LAB C2: Abnormally Long DNS Query - Possible DNS Tunnelling"; content:"|00 01 00 00|"; dsize:>100; classtype:policy-violation; sid:1000008; rev:1;)

# ─────────────────────────────────────────
# EXPLOIT DETECTION
# MITRE ATT&CK: T1210 - Exploitation of Remote Services
# ─────────────────────────────────────────
alert tcp any any -> $HOME_NET 445 (msg:"SOC-LAB EXPLOIT: EternalBlue MS17-010 Attempt"; flow:to_server,established; content:"|FF|SMB"; content:"|00 00 00 00 00 00 00 00|"; distance:4; classtype:attempted-admin; sid:1000009; rev:1;)

# ─────────────────────────────────────────
# DATA EXFILTRATION DETECTION
# MITRE ATT&CK: T1041 - Exfiltration Over C2 Channel
# ─────────────────────────────────────────
alert tcp $HOME_NET any -> !$HOME_NET any (msg:"SOC-LAB EXFIL: Large Outbound Transfer Detected"; flow:to_server,established; dsize:>8000; threshold: type threshold, track by_src, count 10, seconds 60; classtype:policy-violation; sid:1000010; rev:1;)
